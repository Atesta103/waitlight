{
  "name": "waitlight",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:watch": "vitest",
    "docs": "typedoc",
    "docs:rank": "tsx scripts/rank-specs.ts",
    "docs:link": "tsx scripts/link-specs.ts",
    "gen:types": "supabase gen types typescript --project-id zoawkvmwpprtwrueqnxr > types/database.ts",
    "check:app-ui-contract": "node scripts/check-app-storybook-contract.mjs",
    "check:dead-exports": "node scripts/check-dead-exports.mjs",
    "check:schema-migration": "node scripts/check-schema-migration.mjs",
    "ci:app": "npm run check:app-ui-contract && npm run lint && npm run typecheck && npm run test:unit && npm run build",
    "ci:design-system": "npm run lint && npm run build",
    "ci:all": "npm run ci:app && npm run ci:design-system",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test:storybook": "vitest run --project storybook",
    "chromatic": "npx chromatic --exit-once-uploaded",
    "prepare": "husky"
  },
  "lint-staged": {
    "doc/features/**/*.md": "tsx scripts/rank-specs.ts",
    "{app,components,lib,types}/**/*.{ts,tsx}": "node scripts/check-dead-exports.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.3",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/blocks": "^8.6.14",
    "@storybook/nextjs": "^8.6.14",
    "@storybook/react": "^8.6.14",
    "@storybook/react-vite": "^8.6.14",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.0.18",
    "chromatic": "^16.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "storybook": "^8.6.14",
    "supabase": "^2.83.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.17",
    "typedoc-plugin-markdown": "^4.10.0",
    "typescript": "^5",
    "vite": "^8.0.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.0.18"
  }
}
