{
  "plugin": ["typedoc-plugin-markdown"],
  "entryPoints": [
    "lib/actions/auth.ts",
    "lib/actions/queue.ts",
    "lib/actions/settings.ts",
    "lib/actions/onboarding.ts",
    "lib/actions/qr.ts",
    "lib/validators/auth.ts",
    "lib/validators/queue.ts",
    "lib/validators/settings.ts",
    "lib/validators/onboarding.ts",
    "lib/utils/qr-config.ts",
    "lib/utils/qr-token.ts",
    "types/database.ts",
    "app/auth/callback/route.ts",
    "proxy.ts"
  ],
  "entryPointStrategy": "expand",
  "out": "doc/api",
  "readme": "none",
  "mergeReadme": false,
  "hidePageHeader": false,
  "hideBreadcrumbs": false,
  "useCodeBlocks": true,
  "expandObjects": true,
  "parametersFormat": "table",
  "propertiesFormat": "table",
  "enumMembersFormat": "table",
  "typeDeclarationFormat": "table",
  "indexFormat": "table",
  "outputFileStrategy": "modules",
  "fileExtension": ".md",
  "entryFileName": "README",
  "modulesFileName": "README",
  "excludePrivate": true,
  "excludeProtected": false,
  "excludeInternal": true,
  "excludeExternals": true,
  "skipErrorChecking": true,
  "name": "Wait-Light Backend API",
  "includeVersion": false,
  "categorizeByGroup": true,
  "groupOrder": ["Actions", "Validators", "Types", "Utilities", "*"],
  "navigationModel": {
    "excludeGroups": false,
    "excludeCategories": false,
    "excludeFolders": false
  }
}
