# Supabase — get these values from your Supabase project settings → API
# https://supabase.com/dashboard/project/_/settings/api

# Public keys (safe to expose, protected by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Base URL — used by QR code to build the client-facing join link
# In production, set to your real domain (e.g. https://waitlight.app)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase server-only credentials (never expose in NEXT_PUBLIC_ vars)
# Service role key: Supabase Dashboard -> Settings -> API -> service_role
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Comma-separated list of emails allowed to access /admin
ADMIN_EMAILS=admin@example.com,admin2@example.com

# Stripe — required for billing, checkout, and webhook handling
# Secret key (server-only): https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me

# Recurring Price ID used by checkout (server-only): https://dashboard.stripe.com/products
# Must be a `price_...` id (not a `prod_...` id)
STRIPE_PRICE_ID=price_replace_me

# Webhook signing secret (server-only): `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Enable test mode to bypass QR scanning locally
NEXT_PUBLIC_ENABLE_TEST_MODE="true"

# Resend — email sending for the contact form
# https://resend.com/api-keys
RESEND_API_KEY=re_replace_me
